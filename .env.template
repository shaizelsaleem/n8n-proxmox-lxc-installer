# Workflow Settings
SCHEDULE_INTERVAL_MINUTES=30
MAX_NEWS_ITEMS_PER_RUN=5
VIDEO_DURATION_SECONDS=30
AUDIO_QUALITY=high
VIDEO_QUALITY=high

# FFmpeg Settings
VIDEO_CODEC=libx264
AUDIO_CODEC=aac
VIDEO_BITRATE=2M
AUDIO_BITRATE=128k
FRAME_RATE=30

# Ollama Settings
OLLAMA_MODEL=qwen2.5
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=500

# ComfyUI Settings
COMFYUI_MODEL=sd_xl_base_1.0.safetensors
COMFYUI_STEPS=20
COMFYUI_CFG=8
COMFYUI_SAMPLER=euler
COMFYUI_SCHEDULER=normal

# Logging
LOG_LEVEL=info
LOG_FILE=/home/engine/project/logs/news-bulletin.log

# Performance
MAX_CONCURRENT_PROCESSES=2
CLEANUP_TEMP_FILES=true
TEMP_FILE_RETENTION_HOURS=24